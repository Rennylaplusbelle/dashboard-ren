            <td><span class="signal signal-${x.type.toLowerCase()}"><i data-lucide="${x.type==='LONG'?'trending-up':x.type==='SHORT'?'trending-down':x.type==='ACCUM'?'gem':x.type==='WAIT'?'pause':'alert-triangle'}"></i>${x.c}</span></td>
