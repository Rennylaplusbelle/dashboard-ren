    lucide.createIcons();
    
    // Fibo levels
    const levels=[{l:'78.6%',v:selected.l+(selected.h-selected.l)*0.214},{l:'61.8%',v:selected.f618},{l:'50.0%',v:(selected.h+selected.l)/2},{l:'38.2%',v:selected.f382},{l:'23.6%',v:selected.l+(selected.h-selected.l)*0.764},{l:'0% Low',v:selected.l},{l:'100% High',v:selected.h},{l:'127.2%',v:selected.e127},{l:'161.8%',v:selected.e161}];
    document.getElementById('fiboLevels').innerHTML=levels.map(x=>`<div class="fibo-level ${Math.abs(selected.p-x.v)<selected.p*0.03?'current':''}"><span class="fibo-label">${x.l}</span><span class="fibo-value ${x.l.includes('127')||x.l.includes('161')?'cyan':''}">$${x.v.toFixed(2)}</span></div>`).join('');
    
    // Setup box
    const gain=selected.obj-selected.ent;
    const risk=selected.ent-selected.stop;
    const rrRating=selected.rr<1?'Bad':selected.rr<1.5?'Low':selected.rr<2.5?'Good':'Excellent';
    const rrIcon=selected.rr<1?'x-circle':selected.rr<1.5?'alert-circle':selected.rr<2.5?'check-circle':'star';
    document.getElementById('setupBox').innerHTML=`
        <div class="setup-type"><i data-lucide="${selected.type==='LONG'?'trending-up':'trending-down'}"></i>${selected.type}</div>
        <div class="setup-row"><span>Entry</span><span class="green">$${selected.ent.toFixed(2)}</span></div>
        <div class="setup-row"><span>Target</span><span class="cyan">$${selected.obj.toFixed(2)}</span></div>
        <div class="setup-row"><span>Stop Loss</span><span class="red">$${selected.stop.toFixed(2)}</span></div>
        <div class="setup-row"><span>Gain</span><span class="green">+$${gain.toFixed(2)}</span></div>
        <div class="setup-row"><span>Risk</span><span class="red">-$${risk.toFixed(2)}</span></div>
        <div class="rr-box">
            <div class="rr-formula">R/R = $${gain.toFixed(2)} / $${risk.toFixed(2)} = ${selected.rr.toFixed(2)}x</div>
            <div class="rr-explain">You gain $${selected.rr.toFixed(2)} for every $1 risked</div>
            <div class="rr-rating ${selected.rr>=2.5?'bg-mint':selected.rr>=1.5?'bg-gold':'bg-red'}"><i data-lucide="${rrIcon}"></i>${rrRating}</div>
        </div>`;
    lucide.createIcons();
}

// FILTERS
function applyFilters(){
    const sig=document.getElementById('signalFilter').value;
    const scr=document.getElementById('screenFilter').value;
    const sec=document.getElementById('sectorFilter').value;
    const q=document.getElementById('searchInput').value.toLowerCase();
    
    filtered=stocks.filter(x=>{
        if(sig!=='all'&&x.c!==sig)return false;
        if(scr!=='all'&&!x.screen.includes(scr))return false;
        if(sec!=='all'&&!x.s.includes(sec))return false;
        if(q&&!x.t.toLowerCase().includes(q)&&!x.n.toLowerCase().includes(q)&&!x.s.toLowerCase().includes(q))return false;
        return true;
    });
    sortData();updateStats();renderWatchlist();renderTable();
}
function filterSpecial(type){
    if(type==='top')filtered=stocks.filter(x=>x.sc>=85);
    else if(type==='gems')filtered=stocks.filter(x=>x.sc>=85&&x.rr>=2.5);
    sortData();updateStats();renderWatchlist();renderTable();
}
function sortTable(col){sortCol=col;sortAsc=!sortAsc;sortData();renderTable();}
function sortData(){filtered.sort((a,b)=>sortAsc?(a[sortCol]||0)-(b[sortCol]||0):(b[sortCol]||0)-(a[sortCol]||0));}

// QUICK ENTRY
function quickEntry(){
    const ticker=document.getElementById('entryTickerQuick').value.toUpperCase();
    const s=stocks.find(x=>x.t===ticker);
    if(!s){alert('Stock not found');return;}
    selectStock(ticker);
    analyzeEntryForStock(s);
}

// ENTRY TIMING
function analyzeEntryTiming(){
    const ticker=document.getElementById('entryTickerSelect').value||document.getElementById('entryTickerInput').value.toUpperCase();
    const s=stocks.find(x=>x.t===ticker);
    if(!s){document.getElementById('entryResult').innerHTML='<p style="color:var(--accent-red)">Stock not found</p>';return;}
    analyzeEntryForStock(s);
}

function analyzeEntryForStock(s){
    const currentVsEntry=((s.p-s.ent)/s.ent*100).toFixed(1);
    const nearEntry=Math.abs(parseFloat(currentVsEntry))<5;
    const aboveEntry=s.p>s.ent*1.05;
    const belowEntry=s.p<s.ent*0.95;
    const lang=document.querySelector('.lang-btn.active')?.textContent==='FR'?'fr':'en';
    
    const pullback5=(s.p*0.95).toFixed(2);
    const pullback10=(s.p*0.90).toFixed(2);
    const fib618=s.f618.toFixed(2);
    
    let recommendation,recClass;
    if(s.c==='E'||s.c==='B'){recommendation=lang==='fr'?'ÉVITER':'AVOID';recClass='badge-sell';}
    else if(belowEntry&&s.rv<-70){recommendation=lang==='fr'?'ACHETER':'BUY NOW';recClass='badge-buy';}
    else if(nearEntry&&(s.c==='A'||s.c==='C')){recommendation=lang==='fr'?'ACHETER':'BUY NOW';recClass='badge-buy';}
    else if(aboveEntry){recommendation=lang==='fr'?'ATTENDRE':'WAIT';recClass='badge-hold';}
    else{recommendation=lang==='fr'?'ACCUMULER':'SCALE IN';recClass='badge-hold';}
    
    const fc=s.forecast2026||{};
    const stopLossPercent=((s.p-s.stop)/s.p*100).toFixed(1);
    
    const result=`
        <div class="result-header">
            <div class="result-title"><i data-lucide="crosshair"></i>${s.t} — ${lang==='fr'?'Analyse d\'Entrée':'Entry Analysis'}</div>
            <span class="result-badge ${recClass}">${recommendation}</span>
        </div>
        <div class="result-metrics">
            <div class="result-metric"><div class="result-metric-value">$${s.p.toFixed(2)}</div><div class="result-metric-label">${lang==='fr'?'Prix Actuel':'Current'}</div></div>
            <div class="result-metric"><div class="result-metric-value mint">$${s.ent.toFixed(2)}</div><div class="result-metric-label">${lang==='fr'?'Entrée Idéale':'Ideal Entry'}</div></div>
            <div class="result-metric"><div class="result-metric-value cyan">$${s.obj.toFixed(2)}</div><div class="result-metric-label">${lang==='fr'?'Objectif':'Target'}</div></div>
            <div class="result-metric"><div class="result-metric-value ${parseFloat(currentVsEntry)>0?'red':'green'}">${currentVsEntry}%</div><div class="result-metric-label">vs ${lang==='fr'?'Entrée':'Entry'}</div></div>
        </div>
        
        <div class="entry-levels">
            ${belowEntry?`<div class="entry-level buy-now"><i data-lucide="check-circle" class="mint"></i><span class="entry-price mint">$${s.p.toFixed(2)}</span><span class="entry-desc">${lang==='fr'?'ACTUEL — Sous l\'entrée, acheter maintenant':'CURRENT — Below entry, buy now'}</span></div>`:''}
            <div class="entry-level ${nearEntry?'buy-now':'wait'}"><i data-lucide="target" class="${nearEntry?'mint':'gold'}"></i><span class="entry-price ${nearEntry?'mint':'gold'}">$${s.ent.toFixed(2)}</span><span class="entry-desc">${lang==='fr'?'ENTRÉE IDÉALE — Zone Fibonacci optimale':'IDEAL ENTRY — Fibonacci optimal zone'}</span></div>
            <div class="entry-level wait"><i data-lucide="clock" class="gold"></i><span class="entry-price gold">$${pullback5}</span><span class="entry-desc">${lang==='fr'?'PULLBACK -5% — Bon point d\'accumulation':'5% PULLBACK — Good scaling point'}</span></div>
            <div class="entry-level wait"><i data-lucide="git-branch" class="gold"></i><span class="entry-price gold">$${fib618}</span><span class="entry-desc">${lang==='fr'?'FIB 61.8% — Support technique':'FIB 61.8% — Key support'}</span></div>
            <div class="entry-level stop"><i data-lucide="x-circle" class="red"></i><span class="entry-price red">$${s.stop.toFixed(2)}</span><span class="entry-desc">${lang==='fr'?'STOP LOSS — Sortir sous ce niveau':'STOP LOSS — Exit below'}</span></div>
        </div>
        
        ${fc.target?`<div class="forecast-box"><div class="forecast-title"><i data-lucide="trending-up"></i>${lang==='fr'?'PRÉVISIONS WALL STREET 2026':'2026 WALL STREET FORECAST'}</div><div class="forecast-grid"><div class="forecast-item"><div class="forecast-value mint">$${fc.target}</div><div class="forecast-label">Target</div></div><div class="forecast-item"><div class="forecast-value gold">${fc.consensus}</div><div class="forecast-label">Consensus</div></div><div class="forecast-item"><div class="forecast-value cyan">${fc.analysts}</div><div class="forecast-label">${lang==='fr'?'Analystes':'Analysts'}</div></div></div></div>`:''}
        
        <div class="result-section" style="background:var(--bg-elevated);padding:14px;border-radius:8px;border-left:4px solid var(--accent-mint)">
            <h4><i data-lucide="clipboard"></i>${lang==='fr'?'Plan de Trade':'Trade Plan'}</h4>
            <p>• <strong>${lang==='fr'?'Entrée':'Entry'}:</strong> $${s.ent.toFixed(2)}<br>
            • <strong>${lang==='fr'?'Objectif':'Target'}:</strong> $${s.obj.toFixed(2)} (+${s.pot}%)<br>
            • <strong>Stop:</strong> $${s.stop.toFixed(2)} (-${stopLossPercent}%)<br>
            • <strong>R/R:</strong> ${s.rr.toFixed(1)}x</p>
        </div>`;
    
    document.getElementById('entryResult').innerHTML=result;
    lucide.createIcons();
}

// SHOW ANALYSIS
function showAnalysis(ticker){
    const s=stocks.find(x=>x.t===ticker);
    if(!s)return;
    selectStock(ticker);
    const fc=s.forecast2026||{};
    
    let msg=`${s.t} — Wall Street Analysis\n\n`;
    msg+=`Signal: ${s.type} (${s.c})\nScore: ${s.sc}/100\nR/R: ${s.rr.toFixed(1)}x\nPotential: +${s.pot}%\n\n`;
    msg+=`Entry: $${s.ent} → Target: $${s.obj}\nStop: $${s.stop}\n\n`;
    if(fc.target){
        msg+=`═══ 2026 FORECAST ═══\n`;
        msg+=`Revenue: ${fc.revenue}\nEPS: ${fc.eps}\nTarget: $${fc.target}\nConsensus: ${fc.consensus} (${fc.analysts} analysts)\n\n`;
        if(fc.catalysts)msg+=`Catalysts:\n• ${fc.catalysts.join('\n• ')}\n\n`;
        if(fc.risks)msg+=`Risks:\n• ${fc.risks.join('\n• ')}\n\n`;
        if(fc.moat)msg+=`Moat: ${fc.moat}\nTAM: ${fc.tam}`;
    }
    alert(msg);
}

