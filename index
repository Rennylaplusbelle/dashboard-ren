// SELECT STOCK
function selectStock(ticker){
    selected=stocks.find(x=>x.t===ticker);
    if(!selected)return;
    renderWatchlist();renderTable();
    document.getElementById('dTicker').textContent=selected.t;
    document.getElementById('dName').textContent=selected.n;
    document.getElementById('dPrice').innerHTML='<span class="'+(selected.chg>0?'green':'red')+'">$'+selected.p.toFixed(2)+'</span>';
    document.getElementById('dScore').textContent=selected.sc;
    document.getElementById('dRR').textContent=selected.rr.toFixed(2)+'x';
    document.getElementById('dPot').textContent=(selected.pot>0?'+':'')+selected.pot+'%';
    document.getElementById('dCat').textContent=selected.c;
    document.getElementById('dCat').className='metric-value '+(selected.c==='A'?'mint':selected.c==='B'?'red':selected.c==='C'?'purple':selected.c==='D'?'gold':'orange');
    
