}

// RENDER WATCHLIST
function renderWatchlist(){
    document.getElementById('watchlist').innerHTML=filtered.map(x=>`<div class="stock-row ${selected.t===x.t?'selected':''}" onclick="selectStock('${x.t}')"><div><div class="stock-ticker">${x.t}</div><div class="stock-sector">${x.s}</div></div><div class="stock-price">$${x.p.toFixed(2)}</div><div class="stock-score ${x.sc>=80?'score-high':x.sc>=60?'score-med':'score-low'}">${x.sc}</div></div>`).join('');
}

// RENDER TABLE
function renderTable(){
    document.getElementById('tableBody').innerHTML=filtered.map(x=>{
        const screenTags=x.screen.map(s=>`<span class="screen-tag screen-${s}"><i data-lucide="${s==='growth'?'trending-up':s==='value'?'dollar-sign':'gift'}"></i></span>`).join('');
        return `<tr class="${selected.t===x.t?'selected-row':''}" onclick="selectStock('${x.t}')">
