    /* HEADER */
    .header{background:linear-gradient(180deg,rgba(12,18,28,0.98) 0%,rgba(12,18,28,0.95) 100%);border-bottom:1px solid var(--border-accent);padding:10px 20px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:1000;backdrop-filter:blur(20px) saturate(1.5)}
    .logo{display:flex;align-items:center;gap:12px}
