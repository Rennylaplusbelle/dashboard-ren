// RISK ANALYSIS - SIMPLIFIED
function analyzeRisk(){
    const ticker=document.getElementById('riskTickerSelect').value;
    const s=stocks.find(x=>x.t===ticker);
    if(!s){document.getElementById('riskResult').innerHTML='<p class="red">Select a stock</p>';return;}
    
    const sectorKey=Object.keys(sectorData).find(k=>sectorData[k].mine.includes(s.t));
    const sector=sectorData[sectorKey]||{reason:'Unknown',avgChg:0};
    const fc=s.forecast2026||{};
    const lang=document.querySelector('.lang-btn.active')?.textContent==='FR'?'fr':'en';
    
    let riskScore=0;
    if(sector.avgChg<0)riskScore+=25;
    if(s.debt>1)riskScore+=30;else if(s.debt>0.5)riskScore+=15;
    if(s.roe<0)riskScore+=25;else if(s.roe<10)riskScore+=10;
    if(s.pe>100||s.pe===0)riskScore+=20;else if(s.pe>40)riskScore+=10;
    if(s.c==='E')riskScore+=20;else if(s.c==='B')riskScore+=15;
    
    const worstCase=(s.stop*0.85).toFixed(2);
    const maxLoss=((s.p-parseFloat(worstCase))/s.p*100).toFixed(1);
    const stopLoss=((s.p-s.stop)/s.p*100).toFixed(1);
    
    // Balance sheet analysis - pedagogical
    let balanceAnalysis='';
    if(s.debt>1){
        balanceAnalysis=lang==='fr'
            ?`<strong class="red">Dette élevée (D/E: ${s.debt})</strong> — L'entreprise est très endettée. Si les taux d'intérêt montent ou si les revenus baissent, elle pourrait avoir des difficultés à rembourser. Risque de faillite dans un scénario défavorable.`
            :`<strong class="red">High debt (D/E: ${s.debt})</strong> — The company is highly leveraged. If interest rates rise or revenue drops, it could struggle to repay. Bankruptcy risk in adverse scenario.`;
    }else if(s.debt>0.5){
        balanceAnalysis=lang==='fr'
            ?`<strong class="gold">Dette modérée (D/E: ${s.debt})</strong> — Niveau de dette gérable mais à surveiller. L'entreprise utilise l'effet de levier pour croître.`
            :`<strong class="gold">Moderate debt (D/E: ${s.debt})</strong> — Manageable debt level but monitor. Company uses leverage for growth.`;
    }else{
        balanceAnalysis=lang==='fr'
            ?`<strong class="green">Bilan solide (D/E: ${s.debt})</strong> — Faible endettement, l'entreprise a une marge de sécurité financière importante.`
            :`<strong class="green">Strong balance sheet (D/E: ${s.debt})</strong> — Low debt, the company has significant financial cushion.`;
    }
    
    // Profitability analysis
    let profitAnalysis='';
    if(s.roe<0){
        profitAnalysis=lang==='fr'
            ?`<strong class="red">Non rentable (ROE: ${s.roe}%)</strong> — L'entreprise brûle du cash. ${fc.cashBurn?'Burn rate: '+fc.cashBurn+'. ':''}${fc.runway?'Cash runway: '+fc.runway+'. ':''}Risque de dilution si augmentation de capital nécessaire pour financer les opérations.`
            :`<strong class="red">Unprofitable (ROE: ${s.roe}%)</strong> — Company is burning cash. ${fc.cashBurn?'Burn rate: '+fc.cashBurn+'. ':''}${fc.runway?'Cash runway: '+fc.runway+'. ':''}Dilution risk if capital raise needed to fund operations.`;
    }else if(s.roe>15){
        profitAnalysis=lang==='fr'
            ?`<strong class="green">Très rentable (ROE: ${s.roe}%)</strong> — L'entreprise génère d'excellents retours sur les capitaux propres. C'est un signe de moat compétitif.`
            :`<strong class="green">Highly profitable (ROE: ${s.roe}%)</strong> — Company generates excellent returns on equity. Sign of competitive moat.`;
    }else{
        profitAnalysis=lang==='fr'
            ?`<strong class="gold">Rentabilité correcte (ROE: ${s.roe}%)</strong> — L'entreprise est profitable mais sans avantage compétitif majeur.`
            :`<strong class="gold">Decent profitability (ROE: ${s.roe}%)</strong> — Company is profitable but without major competitive advantage.`;
    }
    
    // Worst case scenario
    let worstCaseAnalysis=lang==='fr'
        ?`Si ${s.t} casse le support à <strong class="red">$${s.stop}</strong> avec une rotation sectorielle défavorable, un déclin jusqu'à <strong class="red">$${worstCase}</strong> est possible. Cela représenterait une perte de <strong class="red">-${maxLoss}%</strong> depuis le prix actuel.`
        :`If ${s.t} breaks support at <strong class="red">$${s.stop}</strong> with adverse sector rotation, a decline to <strong class="red">$${worstCase}</strong> is possible. This would represent a <strong class="red">-${maxLoss}%</strong> loss from current price.`;
    
    document.getElementById('riskResult').innerHTML=`
        <div class="result-header">
            <div class="result-title"><i data-lucide="shield"></i>${s.t} — ${lang==='fr'?'Évaluation des Risques':'Risk Assessment'}</div>
            <span class="result-badge ${riskScore>60?'badge-sell':riskScore>30?'badge-hold':'badge-buy'}">${riskScore>60?(lang==='fr'?'RISQUE ÉLEVÉ':'HIGH RISK'):riskScore>30?(lang==='fr'?'MODÉRÉ':'MODERATE'):(lang==='fr'?'FAIBLE':'LOW')}</span>
        </div>
        <div class="result-metrics">
            <div class="result-metric"><div class="result-metric-value ${riskScore>60?'red':riskScore>30?'gold':'green'}">${riskScore}/100</div><div class="result-metric-label">Risk Score</div></div>
            <div class="result-metric"><div class="result-metric-value orange">-${stopLoss}%</div><div class="result-metric-label">Stop Loss %</div></div>
            <div class="result-metric"><div class="result-metric-value red">-${maxLoss}%</div><div class="result-metric-label">Worst Case</div></div>
            <div class="result-metric"><div class="result-metric-value">$${worstCase}</div><div class="result-metric-label">Floor Price</div></div>
        </div>
        
        <div class="result-section">
            <h4><i data-lucide="building"></i>${lang==='fr'?'Contexte Sectoriel':'Industry Context'}</h4>
            <p>${sector.reason}</p>
        </div>
        
        <div class="result-section">
            <h4><i data-lucide="credit-card"></i>${lang==='fr'?'Analyse du Bilan':'Balance Sheet Analysis'}</h4>
            <p>${balanceAnalysis}</p>
        </div>
        
        <div class="result-section">
            <h4><i data-lucide="dollar-sign"></i>${lang==='fr'?'Profitabilité':'Profitability'}</h4>
            <p>${profitAnalysis}</p>
        </div>
        
        ${fc.risks?`
        <div class="result-section">
            <h4><i data-lucide="alert-triangle"></i>${lang==='fr'?'Facteurs de Risque 2026':'2026 Risk Factors'}</h4>
            <ul style="color:var(--accent-red)">${fc.risks.map(r=>`<li><strong>${r}</strong></li>`).join('')}</ul>
        </div>`:''}
        
        <div class="result-section">
            <h4><i data-lucide="trending-down"></i>${lang==='fr'?'Scénario Défavorable':'Worst Case Scenario'}</h4>
            <p>${worstCaseAnalysis}</p>
        </div>
        
        <div class="result-section" style="background:var(--bg-elevated);padding:14px;border-radius:8px;border-left:4px solid var(--accent-mint)">
            <h4><i data-lucide="shield-check"></i>${lang==='fr'?'Recommandations':'Recommendations'}</h4>
            <p>• <strong>Stop Loss:</strong> $${s.stop.toFixed(2)}<br>
            • <strong>${lang==='fr'?'Position max':'Max position'}:</strong> ${riskScore>60?'1%':riskScore>30?'2%':'3%'} ${lang==='fr'?'du portefeuille':'of portfolio'}<br>
            • <strong>${lang==='fr'?'Surveillance':'Monitor'}:</strong> ${lang==='fr'?'Rotation sectorielle + volumes':'Sector rotation + volumes'}</p>
        </div>`;
    lucide.createIcons();
}

// COMPARE - ENHANCED WITH 2026 FORECASTS
function compareStocks(){
    const a=stocks.find(x=>x.t===document.getElementById('compareStockA').value);
    const b=stocks.find(x=>x.t===document.getElementById('compareStockB').value);
    if(!a||!b){document.getElementById('compareResult').innerHTML='<p class="red" style="text-align:center;padding:40px">Select two stocks to compare</p>';return;}
    
    const fcA=a.forecast2026||{};
    const fcB=b.forecast2026||{};
    
    const metrics=[
        {name:'Price',a:'$'+a.p.toFixed(2),b:'$'+b.p.toFixed(2),win:null},
        {name:'Rev Growth',a:a.revGrowth+'%',b:b.revGrowth+'%',win:a.revGrowth>b.revGrowth?'a':'b'},
        {name:'EPS Growth',a:a.epsGrowth+'%',b:b.epsGrowth+'%',win:a.epsGrowth>b.epsGrowth?'a':'b'},
        {name:'P/E',a:a.pe||'N/A',b:b.pe||'N/A',win:(a.pe>0&&b.pe>0)?(a.pe<b.pe?'a':'b'):null},
        {name:'D/E',a:a.debt,b:b.debt,win:a.debt<b.debt?'a':'b'},
        {name:'ROE',a:a.roe+'%',b:b.roe+'%',win:a.roe>b.roe?'a':'b'},
        {name:'Fibo Score',a:a.sc,b:b.sc,win:a.sc>b.sc?'a':'b'},
        {name:'R/R Ratio',a:a.rr.toFixed(1)+'x',b:b.rr.toFixed(1)+'x',win:a.rr>b.rr?'a':'b'},
        {name:'POT%',a:'+'+a.pot+'%',b:'+'+b.pot+'%',win:a.pot>b.pot?'a':'b'},
        {name:'2026 Target',a:fcA.target?'$'+fcA.target:'N/A',b:fcB.target?'$'+fcB.target:'N/A',win:(fcA.target&&fcB.target)?((fcA.target/a.p)>(fcB.target/b.p)?'a':'b'):null},
        {name:'Consensus',a:fcA.consensus||'N/A',b:fcB.consensus||'N/A',win:null},
        {name:'Analysts',a:fcA.analysts||'N/A',b:fcB.analysts||'N/A',win:(fcA.analysts&&fcB.analysts)?(fcA.analysts>fcB.analysts?'a':'b'):null}
    ];
    const aWins=metrics.filter(m=>m.win==='a').length;
    const bWins=metrics.filter(m=>m.win==='b').length;
    const winner=aWins>bWins?'a':'b';
    const winnerStock=winner==='a'?a:b;
    const winnerFc=winner==='a'?fcA:fcB;
    
    const lang=document.querySelector('.lang-btn.active')?.textContent==='FR'?'fr':'en';
    
    document.getElementById('compareResult').innerHTML=`
        <div class="compare-grid">
            <div class="compare-card ${winner==='a'?'winner':''}">
                <div class="compare-header">
                    <div class="compare-ticker">${a.t}</div>
                    <div style="font-size:10px;color:var(--text-secondary)">${a.n}</div>
                    ${winner==='a'?`<span class="result-badge badge-buy" style="margin-top:8px">${lang==='fr'?'🏆 GAGNANT':'🏆 WINNER'}</span>`:''}
                </div>
                ${metrics.map(m=>`<div class="compare-row ${m.win==='a'?'winner-row':''}"><span>${m.name}</span><span class="${m.win==='a'?'mint':''}" style="${m.win==='a'?'font-weight:700':''}">${m.a}</span></div>`).join('')}
            </div>
            <div class="compare-vs">VS</div>
            <div class="compare-card ${winner==='b'?'winner':''}">
                <div class="compare-header">
                    <div class="compare-ticker">${b.t}</div>
                    <div style="font-size:10px;color:var(--text-secondary)">${b.n}</div>
                    ${winner==='b'?`<span class="result-badge badge-buy" style="margin-top:8px">${lang==='fr'?'🏆 GAGNANT':'🏆 WINNER'}</span>`:''}
                </div>
                ${metrics.map(m=>`<div class="compare-row ${m.win==='b'?'winner-row':''}"><span>${m.name}</span><span class="${m.win==='b'?'mint':''}" style="${m.win==='b'?'font-weight:700':''}">${m.b}</span></div>`).join('')}
            </div>
        </div>
        
        <div class="panel" style="margin-top:14px">
            <div class="result-section">
                <h4><i data-lucide="trophy"></i>${lang==='fr'?'Verdict':'Verdict'}: ${winnerStock.t} ${lang==='fr'?'gagne':'wins'} ${Math.max(aWins,bWins)}-${Math.min(aWins,bWins)}</h4>
                <p><strong>${winnerStock.t}</strong> ${lang==='fr'?'est le meilleur choix avec':'is the better pick with'} Score ${winnerStock.sc}, R/R ${winnerStock.rr.toFixed(1)}x, ${lang==='fr'?'potentiel':'potential'} +${winnerStock.pot}%.${winnerFc.target?' Target: <span class="mint">$'+winnerFc.target+'</span> ('+winnerFc.consensus+').':''}</p>
            </div>
            ${winnerFc.moat?`<div class="result-section"><h4><i data-lucide="shield"></i>${lang==='fr'?'Avantage Compétitif':'Competitive Moat'}</h4><p>${winnerFc.moat}</p></div>`:''}
            ${winnerFc.tam?`<div class="result-section"><h4><i data-lucide="globe"></i>${lang==='fr'?'Marché Adressable':'Total Addressable Market'}</h4><p>${winnerFc.tam}</p></div>`:''}
        </div>`;
    lucide.createIcons();
}

// PORTFOLIO BUILDER
function buildPortfolio(){
    const amount=parseFloat(document.getElementById('portfolioAmount').value)||10000;
    const strategy=document.getElementById('portfolioStrategy').value;
    const maxStocks=parseInt(document.getElementById('portfolioCount').value)||10;
    
    let candidates=stocks.filter(s=>s.c==='A'||s.c==='C');
    if(strategy==='conservative')candidates=candidates.filter(s=>s.debt<0.5&&s.rr>=1.5).sort((a,b)=>(b.div+b.roe/10)-(a.div+a.roe/10));
    else if(strategy==='aggressive')candidates=candidates.filter(s=>s.pot>30).sort((a,b)=>b.pot-a.pot);
    else candidates=candidates.filter(s=>s.sc>=75).sort((a,b)=>b.sc-a.sc);
    
    const sectorCounts={};const portfolio=[];
    for(const s of candidates){
        if(portfolio.length>=maxStocks)break;
        if(!sectorCounts[s.s])sectorCounts[s.s]=0;
        if(sectorCounts[s.s]<2){portfolio.push(s);sectorCounts[s.s]++;}
    }
    
    const totalScore=portfolio.reduce((a,s)=>a+s.sc,0);
    const allocations=portfolio.map(s=>({...s,alloc:Math.round(s.sc/totalScore*100),amount:Math.round(s.sc/totalScore*amount),shares:Math.floor((s.sc/totalScore*amount)/s.p)}));
    const avgPot=portfolio.reduce((a,s)=>a+s.pot,0)/portfolio.length;
    const avgRR=portfolio.reduce((a,s)=>a+s.rr,0)/portfolio.length;
    
    document.getElementById('portfolioResult').innerHTML=`
        <div class="portfolio-summary">
            <div class="portfolio-stat"><div class="portfolio-stat-value gold">$${amount.toLocaleString()}</div><div class="portfolio-stat-label">Investment</div></div>
            <div class="portfolio-stat"><div class="portfolio-stat-value mint">${portfolio.length}</div><div class="portfolio-stat-label">Positions</div></div>
            <div class="portfolio-stat"><div class="portfolio-stat-value cyan">+${avgPot.toFixed(0)}%</div><div class="portfolio-stat-label">Avg Potential</div></div>
            <div class="portfolio-stat"><div class="portfolio-stat-value purple">${avgRR.toFixed(1)}x</div><div class="portfolio-stat-label">Avg R/R</div></div>
        </div>
        <div class="panel"><table class="data-table"><thead><tr><th>Ticker</th><th>Sector</th><th>Price</th><th>Alloc</th><th>Amount</th><th>Shares</th><th>Entry</th><th>Target</th><th>Stop</th></tr></thead><tbody>
        ${allocations.map(s=>`<tr><td class="mint" style="font-weight:700">${s.t}</td><td>${s.s}</td><td>$${s.p.toFixed(2)}</td><td><div class="allocation-bar"><div class="allocation-fill" style="width:${s.alloc}%"></div></div>${s.alloc}%</td><td class="gold">$${s.amount.toLocaleString()}</td><td>${s.shares}</td><td class="green">$${s.ent}</td><td class="cyan">$${s.obj}</td><td class="red">$${s.stop}</td></tr>`).join('')}
        </tbody></table></div>`;
    lucide.createIcons();
}

