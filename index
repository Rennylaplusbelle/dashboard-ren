    .header-actions{display:flex;align-items:center;gap:12px}
    .clock{font-family:var(--font-mono);font-size:11px;color:var(--accent-mint);padding:6px 12px;border:1px solid var(--accent-mint);border-radius:6px;background:rgba(0,229,176,0.08);display:flex;align-items:center;gap:6px}
    .clock i{width:14px;height:14px}
    
    /* LANGUAGE TOGGLE */
    .lang-toggle{display:flex;gap:4px;padding:4px;background:var(--bg-card);border-radius:8px;border:1px solid var(--border-subtle)}
    .lang-btn{padding:6px 12px;border:none;border-radius:6px;font-size:10px;font-weight:600;cursor:pointer;transition:all 0.2s;background:transparent;color:var(--text-muted);font-family:var(--font-sans)}
    .lang-btn.active{background:var(--gradient-premium);color:#000}
    .lang-btn:hover:not(.active){color:var(--text-primary)}
    
    /* BANNER */
    .ren-banner{background:linear-gradient(90deg,transparent,rgba(0,229,176,0.1),transparent);border-top:1px solid var(--accent-mint);border-bottom:1px solid var(--accent-mint);padding:8px;text-align:center;position:relative;overflow:hidden}
    .ren-banner::before{content:'';position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1545569341-9eb8b30979d9?w=1920') center/cover;opacity:0.05}
    .ren-text{font-family:var(--font-sans);font-size:14px;font-weight:800;letter-spacing:10px;background:var(--gradient-premium);-webkit-background-clip:text;-webkit-text-fill-color:transparent;position:relative}
    
    /* TABS */
    .tabs-container{background:var(--bg-panel);border-bottom:1px solid var(--border-subtle);padding:0 12px;display:flex;gap:4px;overflow-x:auto}
    .tabs-container::-webkit-scrollbar{height:0}
    .tab-btn{background:transparent;border:none;color:var(--text-muted);padding:12px 14px;font-family:var(--font-sans);font-size:11px;font-weight:600;cursor:pointer;transition:all 0.2s;position:relative;white-space:nowrap;display:flex;align-items:center;gap:6px;border-radius:6px 6px 0 0}
    .tab-btn i{width:14px;height:14px}
    .tab-btn:hover{color:var(--text-secondary);background:rgba(255,255,255,0.02)}
    .tab-btn.active{color:var(--accent-mint);background:rgba(0,229,176,0.05)}
    .tab-btn.active::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gradient-premium)}
    .tab-content{display:none;padding:12px}.tab-content.active{display:block}
    
    /* UTILITY CLASSES */
    .mint{color:var(--accent-mint)}.cyan{color:var(--accent-cyan)}.gold{color:var(--accent-gold)}.red{color:var(--accent-red)}.green{color:var(--accent-green)}.purple{color:var(--accent-purple)}.orange{color:var(--accent-orange)}
    .bg-mint{background:rgba(0,229,176,0.12)}.bg-gold{background:rgba(245,158,11,0.12)}.bg-red{background:rgba(239,68,68,0.12)}.bg-green{background:rgba(16,185,129,0.12)}
    
    /* INSIGHT BOXES - NEW CATCHY STYLE */
    .insight-box{background:linear-gradient(135deg,rgba(59,130,246,0.15),rgba(139,92,246,0.1));border:1px solid rgba(59,130,246,0.3);border-radius:12px;padding:16px;margin:14px 0;position:relative;overflow:hidden}
    .insight-box::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%;background:var(--gradient-premium)}
    .insight-box.warning{background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(217,119,6,0.1));border-color:rgba(245,158,11,0.3)}
    .insight-box.warning::before{background:var(--gradient-gold)}
    .insight-box.danger{background:linear-gradient(135deg,rgba(239,68,68,0.15),rgba(220,38,38,0.1));border-color:rgba(239,68,68,0.3)}
    .insight-box.danger::before{background:var(--gradient-danger)}
    .insight-box.success{background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(5,150,105,0.1));border-color:rgba(16,185,129,0.3)}
    .insight-box.success::before{background:linear-gradient(135deg,#10b981,#059669)}
    .insight-title{font-size:13px;font-weight:800;margin-bottom:8px;display:flex;align-items:center;gap:8px;letter-spacing:0.5px}
    .insight-title i{width:18px;height:18px}
    .insight-content{font-size:11px;line-height:1.7;color:var(--text-secondary)}
    .insight-content strong{color:var(--text-primary);font-weight:700}
    .insight-highlight{display:inline-block;background:rgba(0,229,176,0.2);padding:2px 8px;border-radius:4px;font-weight:700;color:var(--accent-mint);margin:0 2px}
    .insight-danger{display:inline-block;background:rgba(239,68,68,0.2);padding:2px 8px;border-radius:4px;font-weight:700;color:var(--accent-red);margin:0 2px}
    .insight-warning{display:inline-block;background:rgba(245,158,11,0.2);padding:2px 8px;border-radius:4px;font-weight:700;color:var(--accent-gold);margin:0 2px}
    
    /* DEDUCTION BOX */
    .deduction-box{background:var(--bg-elevated);border-radius:10px;padding:14px;margin:12px 0;border-left:4px solid var(--accent-purple)}
    .deduction-title{font-size:12px;font-weight:700;color:var(--accent-purple);margin-bottom:8px;display:flex;align-items:center;gap:6px}
    .deduction-title i{width:16px;height:16px}
    .deduction-item{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid var(--border-subtle);font-size:11px}
    .deduction-item:last-child{border-bottom:none}
    .deduction-icon{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .deduction-icon.positive{background:rgba(16,185,129,0.2);color:var(--accent-green)}
    .deduction-icon.negative{background:rgba(239,68,68,0.2);color:var(--accent-red)}
    .deduction-icon.neutral{background:rgba(245,158,11,0.2);color:var(--accent-gold)}
    .deduction-icon i{width:14px;height:14px}
    .deduction-text{flex:1}
    .deduction-label{font-weight:600;color:var(--text-primary)}
    .deduction-detail{color:var(--text-secondary);margin-top:2px}
    
    /* RISK METER */
    .risk-meter{background:var(--bg-card);border-radius:12px;padding:16px;margin:14px 0;border:1px solid var(--border-subtle)}
    .risk-meter-title{font-size:11px;color:var(--text-muted);text-transform:uppercase;margin-bottom:10px;letter-spacing:1px}
    .risk-meter-bar{height:12px;background:linear-gradient(90deg,#10b981 0%,#f59e0b 50%,#ef4444 100%);border-radius:6px;position:relative}
    .risk-meter-indicator{position:absolute;top:-4px;width:20px;height:20px;background:#fff;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,0.3);transform:translateX(-50%)}
    .risk-meter-labels{display:flex;justify-content:space-between;margin-top:6px;font-size:9px;color:var(--text-muted)}
    
    /* PANELS */
    .panel{background:var(--bg-panel);padding:14px;backdrop-filter:blur(10px);border-radius:10px;border:1px solid var(--border-subtle);margin-bottom:10px}
    .panel-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border-subtle)}
    .panel-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text-secondary);display:flex;align-items:center;gap:8px}
    .panel-title i{width:16px;height:16px;color:var(--accent-mint)}
    .panel-badge{font-size:10px;padding:4px 10px;border-radius:20px;background:var(--bg-elevated);color:var(--accent-gold);font-weight:600;font-family:var(--font-mono)}
    
    /* MAIN GRID */
    .main-grid{display:grid;grid-template-columns:170px 1fr 220px;gap:10px;min-height:calc(100vh - 220px)}
    
    /* FILTERS */
    .filters{grid-column:1/-1;display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--bg-panel);border-radius:10px;flex-wrap:wrap;border:1px solid var(--border-subtle)}
    .filter-group{display:flex;align-items:center;gap:6px}
    .filter-label{font-size:9px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;display:flex;align-items:center;gap:4px}
    .filter-label i{width:12px;height:12px}
    .filter-select{background:var(--bg-card);border:1px solid var(--border-subtle);color:var(--text-primary);padding:6px 10px;border-radius:6px;font-size:11px;font-family:var(--font-sans);cursor:pointer;min-width:100px}
    .filter-select:focus{outline:none;border-color:var(--accent-mint)}
    .filter-btn{background:var(--bg-card);border:1px solid var(--border-subtle);color:var(--text-secondary);padding:6px 10px;border-radius:6px;cursor:pointer;font-family:var(--font-sans);font-size:10px;font-weight:500;transition:all 0.2s;display:flex;align-items:center;gap:4px}
    .filter-btn i{width:12px;height:12px}
    .filter-btn:hover{border-color:var(--accent-mint);color:var(--text-primary)}
    .filter-btn.active{background:var(--gradient-premium);color:#000;font-weight:700;border-color:transparent}
    .search-box{display:flex;align-items:center;gap:6px;background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:6px;padding:4px 10px;margin-left:auto}
    .search-box i{width:14px;height:14px;color:var(--text-muted)}
    .search-input{background:transparent;border:none;color:var(--text-primary);font-size:11px;width:100px;font-family:var(--font-sans)}
    .search-input:focus{outline:none}
    .search-input::placeholder{color:var(--text-muted)}
    
    /* BUTTONS */
    .btn{background:var(--gradient-premium);border:none;color:#000;padding:8px 14px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;transition:all 0.2s;font-family:var(--font-sans);display:inline-flex;align-items:center;gap:6px}
    .btn i{width:14px;height:14px}
    .btn:hover{transform:translateY(-1px);box-shadow:var(--glow-mint)}
    .btn-sm{padding:4px 10px;font-size:10px;border-radius:5px}
    .btn-sm i{width:12px;height:12px}
    .btn-outline{background:transparent;border:1px solid var(--accent-mint);color:var(--accent-mint)}
    .btn-gold{background:var(--gradient-gold)}
    .btn-danger{background:var(--gradient-danger);color:#fff}
    
    /* WATCHLIST */
    .watchlist{overflow-y:auto;max-height:calc(100vh - 300px)}
    .stock-row{display:grid;grid-template-columns:50px 1fr 28px;gap:6px;padding:8px 10px;border-bottom:1px solid var(--border-subtle);cursor:pointer;transition:all 0.15s;align-items:center}
    .stock-row:hover{background:var(--bg-hover)}
    .stock-row.selected{background:rgba(0,229,176,0.1);border-left:3px solid var(--accent-mint)}
    .stock-ticker{font-weight:700;font-size:11px;font-family:var(--font-mono);color:var(--text-primary)}
    .stock-sector{font-size:9px;color:var(--text-muted)}
    .stock-price{font-size:10px;text-align:right;font-weight:600;color:var(--accent-mint);font-family:var(--font-mono)}
    .stock-score{text-align:center;font-size:10px;font-weight:700;padding:3px 6px;border-radius:5px;font-family:var(--font-mono)}
    .score-high{background:rgba(0,229,176,0.15);color:var(--accent-mint)}
    .score-med{background:rgba(245,158,11,0.15);color:var(--accent-gold)}
    .score-low{background:rgba(239,68,68,0.15);color:var(--accent-red)}
    
    /* DATA TABLE */
    .table-container{overflow:auto;max-height:calc(100vh - 300px);border-radius:10px}
    .data-table{width:100%;border-collapse:collapse;font-size:11px}
    .data-table th{background:var(--bg-elevated);padding:10px 8px;text-align:left;font-weight:600;color:var(--accent-gold);text-transform:uppercase;font-size:9px;position:sticky;top:0;border-bottom:2px solid var(--accent-gold);cursor:pointer;white-space:nowrap;z-index:10;letter-spacing:0.5px}
    .data-table th:hover{background:rgba(245,158,11,0.15)}
    .data-table td{padding:8px;border-bottom:1px solid var(--border-subtle);font-family:var(--font-mono);font-size:10px}
    .data-table tbody tr:hover{background:var(--bg-hover)}
    .data-table tbody tr.selected-row{background:rgba(0,229,176,0.1)}
    
    /* SIGNALS */
    .signal{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:5px;font-size:9px;font-weight:700;font-family:var(--font-sans)}
    .signal i{width:10px;height:10px}
    .signal-long{background:linear-gradient(135deg,rgba(0,229,176,0.2),rgba(0,196,232,0.1));color:var(--accent-mint);border:1px solid rgba(0,229,176,0.3)}
    .signal-short{background:linear-gradient(135deg,rgba(239,68,68,0.2),rgba(220,38,38,0.1));color:var(--accent-red);border:1px solid rgba(239,68,68,0.3)}
    .signal-accum{background:linear-gradient(135deg,rgba(139,92,246,0.2),rgba(124,58,237,0.1));color:var(--accent-purple);border:1px solid rgba(139,92,246,0.3)}
    .signal-wait{background:linear-gradient(135deg,rgba(245,158,11,0.2),rgba(217,119,6,0.1));color:var(--accent-gold);border:1px solid rgba(245,158,11,0.3)}
    .signal-avoid{background:linear-gradient(135deg,rgba(249,115,22,0.2),rgba(234,88,12,0.1));color:var(--accent-orange);border:1px solid rgba(249,115,22,0.3)}
    
    /* SCREEN TAGS */
    .screen-tag{display:inline-flex;align-items:center;gap:2px;padding:2px 5px;border-radius:4px;font-size:8px;font-weight:600;margin-left:2px}
    .screen-tag i{width:8px;height:8px}
    .screen-growth{background:rgba(0,229,176,0.1);color:var(--accent-mint)}
    .screen-value{background:rgba(0,196,232,0.1);color:var(--accent-cyan)}
    .screen-dividend{background:rgba(139,92,246,0.1);color:var(--accent-purple)}
    
    /* DETAIL PANEL */
    .detail-header{text-align:center;padding:16px;background:linear-gradient(135deg,rgba(0,229,176,0.08),rgba(245,158,11,0.05));border-radius:10px;margin-bottom:10px;border:1px solid var(--border-accent);position:relative;overflow:hidden}
    .detail-header::before{content:'';position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=600') center/cover;opacity:0.03}
    .detail-ticker{font-size:24px;font-weight:800;color:var(--accent-mint);font-family:var(--font-mono);letter-spacing:3px;position:relative}
    .detail-name{font-size:10px;color:var(--text-secondary);margin-top:4px;position:relative}
    .detail-price{font-size:28px;font-weight:800;margin-top:6px;font-family:var(--font-mono);position:relative}
    .detail-section{margin-bottom:12px}
    .detail-section-title{font-size:10px;color:var(--accent-gold);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--border-subtle);font-weight:600;display:flex;align-items:center;gap:6px}
    .detail-section-title i{width:14px;height:14px}
    
    /* METRICS GRID */
    .metrics-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .metric-box{background:var(--bg-card);padding:10px;border-radius:8px;text-align:center;border:1px solid var(--border-subtle);transition:all 0.2s}
    .metric-box:hover{border-color:var(--accent-mint)}
    .metric-box.highlight{border-color:var(--accent-mint);background:linear-gradient(135deg,rgba(0,229,176,0.1),rgba(0,196,232,0.05));box-shadow:var(--glow-mint)}
    .metric-label{font-size:8px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;display:flex;align-items:center;justify-content:center;gap:4px}
    .metric-label i{width:10px;height:10px}
    .metric-value{font-size:18px;font-weight:800;font-family:var(--font-mono);margin-top:4px}
    .metric-sub{font-size:8px;color:var(--text-dim);margin-top:2px}
    
    /* INVESTMENT INDICATOR */
    .invest-indicator{display:flex;align-items:center;justify-content:center;gap:12px;padding:14px;border-radius:10px;margin:10px 0}
    .invest-indicator.buy{background:linear-gradient(135deg,rgba(0,229,176,0.15),rgba(16,185,129,0.1));border:2px solid var(--accent-mint);animation:glowPulse 2s ease-in-out infinite}
    .invest-indicator.hold{background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(217,119,6,0.1));border:2px solid var(--accent-gold)}
    .invest-indicator.sell{background:linear-gradient(135deg,rgba(239,68,68,0.15),rgba(220,38,38,0.1));border:2px solid var(--accent-red)}
    @keyframes glowPulse{0%,100%{box-shadow:0 0 10px rgba(0,229,176,0.3)}50%{box-shadow:0 0 25px rgba(0,229,176,0.5)}}
    .invest-icon{width:32px;height:32px}
    .invest-text{font-size:18px;font-weight:800;letter-spacing:3px}
    .invest-sub{font-size:9px;color:var(--text-secondary)}
    
    /* FIBO LEVELS */
    .fibo-levels{font-size:10px}
    .fibo-level{display:flex;justify-content:space-between;padding:6px 8px;border-bottom:1px solid var(--border-subtle);transition:all 0.2s}
    .fibo-level:hover{background:var(--bg-hover)}
    .fibo-level.current{background:rgba(0,229,176,0.1);border-left:3px solid var(--accent-mint);font-weight:600}
    .fibo-label{color:var(--text-muted);display:flex;align-items:center;gap:4px}
    .fibo-value{font-weight:600;font-family:var(--font-mono)}
    
    /* SETUP BOX */
    .setup-box{background:var(--bg-card);border-radius:8px;padding:12px;border-left:4px solid var(--accent-mint)}
    .setup-type{font-size:12px;font-weight:700;color:var(--accent-mint);margin-bottom:8px;display:flex;align-items:center;gap:8px}
    .setup-type i{width:16px;height:16px}
    .setup-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--border-subtle);font-size:10px}
    .setup-row:last-child{border-bottom:none}
    .rr-box{background:linear-gradient(135deg,rgba(0,229,176,0.1),rgba(0,196,232,0.05));border:1px solid var(--accent-mint);border-radius:8px;padding:12px;margin-top:8px;text-align:center}
    .rr-formula{font-family:var(--font-mono);font-size:12px;color:var(--accent-mint);font-weight:600}
    .rr-explain{font-size:9px;color:var(--text-secondary);margin-top:4px}
    .rr-rating{display:inline-flex;align-items:center;gap:4px;padding:4px 12px;border-radius:20px;font-size:9px;font-weight:700;margin-top:6px}
    .rr-rating i{width:12px;height:12px}
    
    /* TOOL CONTAINERS */
    .tool-container{max-width:1300px;margin:0 auto}
    .tool-grid{display:grid;grid-template-columns:280px 1fr;gap:14px}
    .tool-sidebar{background:var(--bg-panel);border-radius:10px;padding:16px;border:1px solid var(--border-subtle)}
    .tool-main{background:var(--bg-panel);border-radius:10px;padding:16px;border:1px solid var(--border-subtle)}
    .tool-title{font-size:16px;font-weight:700;color:var(--accent-gold);margin-bottom:6px;display:flex;align-items:center;gap:10px}
    .tool-title i{width:20px;height:20px}
    .tool-subtitle{font-size:10px;color:var(--text-muted);margin-bottom:16px}
    .tool-section{margin-bottom:14px}
    .tool-label{font-size:10px;color:var(--text-secondary);margin-bottom:6px;display:block;font-weight:500}
    .tool-select,.tool-input{background:var(--bg-card);border:1px solid var(--border-subtle);color:var(--text-primary);padding:10px 12px;border-radius:8px;font-size:11px;width:100%;margin-bottom:10px;font-family:var(--font-sans)}
    .tool-select:focus,.tool-input:focus{outline:none;border-color:var(--accent-mint);box-shadow:var(--glow-mint)}
    .tool-result{background:var(--bg-card);border-radius:10px;padding:16px;min-height:350px;max-height:calc(100vh - 320px);overflow-y:auto}
    
    /* RESULT COMPONENTS */
    .result-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--border-subtle)}
    .result-title{font-size:14px;font-weight:700;color:var(--accent-mint);display:flex;align-items:center;gap:8px}
    .result-title i{width:18px;height:18px}
    .result-badge{font-size:11px;padding:6px 14px;border-radius:20px;font-weight:700}
    .badge-buy{background:var(--gradient-premium);color:#000}
    .badge-hold{background:var(--gradient-gold);color:#000}
    .badge-sell{background:var(--gradient-danger);color:#fff}
    .result-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:14px 0}
    .result-metric{background:var(--bg-elevated);padding:12px;border-radius:8px;text-align:center;border:1px solid var(--border-subtle)}
    .result-metric-value{font-size:16px;font-weight:700;font-family:var(--font-mono)}
    .result-metric-label{font-size:8px;color:var(--text-muted);text-transform:uppercase;margin-top:4px;letter-spacing:0.5px}
    .result-section{margin-bottom:14px}
    .result-section h4{font-size:11px;color:var(--accent-gold);margin-bottom:8px;font-weight:600;display:flex;align-items:center;gap:6px}
    .result-section h4 i{width:14px;height:14px}
    .result-section p,.result-section li{font-size:10px;color:var(--text-secondary);line-height:1.6}
    .result-section ul{list-style:none;padding-left:14px}
    .result-section li{padding:3px 0;position:relative}
    .result-section li::before{content:'';position:absolute;left:-10px;top:8px;width:4px;height:4px;background:var(--accent-mint);border-radius:50%}
    
    /* FORECAST BOX */
    .forecast-box{background:linear-gradient(135deg,rgba(59,130,246,0.1),rgba(139,92,246,0.05));border:1px solid rgba(59,130,246,0.3);border-radius:10px;padding:14px;margin:12px 0}
    .forecast-title{font-size:11px;font-weight:700;color:var(--accent-blue);margin-bottom:10px;display:flex;align-items:center;gap:6px}
    .forecast-title i{width:14px;height:14px}
    .forecast-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
    .forecast-item{text-align:center;padding:8px;background:rgba(0,0,0,0.2);border-radius:6px}
    .forecast-value{font-size:14px;font-weight:700;font-family:var(--font-mono)}
    .forecast-label{font-size:8px;color:var(--text-muted);margin-top:2px}
    
    /* ENTRY LEVELS - ENHANCED */
    .entry-levels{margin:14px 0}
    .entry-level{display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:10px;margin-bottom:8px;font-size:11px;border:1px solid var(--border-subtle);transition:all 0.2s}
    .entry-level:hover{transform:translateX(4px)}
    .entry-level i{width:18px;height:18px;flex-shrink:0}
    .entry-level.buy-now{background:linear-gradient(135deg,rgba(0,229,176,0.15),rgba(16,185,129,0.08));border-color:var(--accent-mint)}
    .entry-level.wait{background:linear-gradient(135deg,rgba(245,158,11,0.12),rgba(217,119,6,0.06));border-color:var(--accent-gold)}
    .entry-level.aggressive{background:linear-gradient(135deg,rgba(249,115,22,0.12),rgba(234,88,12,0.06));border-color:var(--accent-orange)}
    .entry-level.stop{background:linear-gradient(135deg,rgba(239,68,68,0.12),rgba(220,38,38,0.06));border-color:var(--accent-red)}
    .entry-price{font-size:15px;font-weight:800;min-width:90px;font-family:var(--font-mono)}
    .entry-desc{flex:1;color:var(--text-secondary)}
    .entry-tag{padding:3px 8px;border-radius:4px;font-size:9px;font-weight:700;text-transform:uppercase}
    
    /* COMPARE */
    .compare-grid{display:grid;grid-template-columns:1fr 70px 1fr;gap:14px;align-items:start}
    .compare-card{background:var(--bg-card);border-radius:10px;padding:16px;border:1px solid var(--border-subtle)}
    .compare-card.winner{border-color:var(--accent-mint);box-shadow:var(--glow-mint)}
    .compare-header{text-align:center;padding-bottom:12px;border-bottom:1px solid var(--border-subtle);margin-bottom:12px}
    .compare-ticker{font-size:22px;font-weight:800;color:var(--accent-mint);font-family:var(--font-mono)}
    .compare-vs{display:flex;align-items:center;justify-content:center;font-size:24px;color:var(--accent-gold);font-weight:800}
    .compare-row{display:flex;justify-content:space-between;padding:6px 0;font-size:10px;border-bottom:1px solid var(--border-subtle)}
    
    /* PORTFOLIO */
    .portfolio-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
    .portfolio-stat{background:var(--bg-card);padding:14px;border-radius:10px;text-align:center;border:1px solid var(--border-subtle)}
    .portfolio-stat-value{font-size:20px;font-weight:800;font-family:var(--font-mono)}
    .portfolio-stat-label{font-size:9px;color:var(--text-muted);text-transform:uppercase;margin-top:4px}
    .allocation-bar{height:10px;background:var(--bg-deep);border-radius:5px;overflow:hidden;margin-top:6px}
    .allocation-fill{height:100%;border-radius:5px;background:var(--gradient-premium)}
    
    /* PHOTONICS */
    .photonics-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:14px}
    .photonics-card{background:var(--bg-card);border-radius:10px;padding:16px;border:1px solid var(--border-subtle)}
    .photonics-card h3{font-size:12px;color:var(--accent-cyan);margin-bottom:12px;display:flex;align-items:center;gap:8px;font-weight:700}
    .photonics-card h3 i{width:16px;height:16px}
    .timeline-item{display:flex;gap:10px;padding:8px 0;border-left:2px solid var(--accent-cyan);padding-left:14px;margin-left:6px}
    .timeline-date{font-size:10px;color:var(--accent-gold);font-weight:600;min-width:60px;font-family:var(--font-mono)}
    .timeline-event{font-size:10px;color:var(--text-secondary)}
    .bottleneck{display:flex;align-items:center;gap:10px;padding:8px 10px;background:var(--bg-elevated);border-radius:6px;margin-bottom:6px;font-size:10px}
    .bottleneck-severity{width:10px;height:10px;border-radius:50%;flex-shrink:0}
    .severity-high{background:var(--accent-red)}
    .severity-med{background:var(--accent-gold)}
    .severity-low{background:var(--accent-green)}
    
    /* HEATMAP */
    .heatmap-content{padding:10px}
    .heatmap-title{font-size:16px;font-weight:700;color:var(--accent-gold);margin-bottom:6px;text-align:center;display:flex;align-items:center;justify-content:center;gap:8px}
    .heatmap-title i{width:20px;height:20px}
    .heatmap-subtitle{font-size:10px;color:var(--text-muted);margin-bottom:14px;text-align:center}
    .rotation-flow{background:var(--bg-card);border-radius:10px;padding:14px;margin-bottom:14px;border:1px solid var(--accent-gold)}
    .rotation-title{font-size:12px;color:var(--accent-gold);font-weight:700;margin-bottom:10px;text-align:center;display:flex;align-items:center;justify-content:center;gap:6px}
    .rotation-title i{width:16px;height:16px}
    .rotation-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:8px}
    .rotation-item{display:flex;align-items:center;gap:8px;background:var(--bg-elevated);padding:8px 12px;border-radius:8px;font-size:10px}
    .rotation-from{color:var(--accent-red);flex:1}
    .rotation-arrow{color:var(--accent-gold);font-weight:700}
    .rotation-arrow i{width:16px;height:16px}
    .rotation-to{color:var(--accent-green);flex:1;text-align:right}
    .heatmap-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px}
    .heatmap-cell{padding:14px 10px;border-radius:10px;text-align:center;cursor:pointer;transition:all 0.3s;border:1px solid transparent}
    .heatmap-cell:hover{transform:scale(1.03);box-shadow:0 4px 20px rgba(0,0,0,0.3)}
    .heatmap-cell .sector-icon{font-size:20px;margin-bottom:6px}
    .heatmap-cell .sector-name{font-size:10px;font-weight:700;margin-bottom:4px}
    .heatmap-cell .sector-perf{font-size:16px;font-weight:800;font-family:var(--font-mono)}
    .heatmap-cell .sector-count{font-size:8px;color:rgba(255,255,255,0.6);margin-top:4px}
    .hot-cell{background:linear-gradient(135deg,rgba(239,68,68,0.3),rgba(220,38,38,0.2));border-color:rgba(239,68,68,0.4)}
    .hot-cell .sector-perf{color:#ff6b6b}
    .warm-cell{background:linear-gradient(135deg,rgba(249,115,22,0.25),rgba(234,88,12,0.15));border-color:rgba(249,115,22,0.35)}
    .warm-cell .sector-perf{color:#fb923c}
    .neutral-cell{background:linear-gradient(135deg,rgba(245,158,11,0.2),rgba(217,119,6,0.1));border-color:rgba(245,158,11,0.3)}
    .neutral-cell .sector-perf{color:#f59e0b}
    .cool-cell{background:linear-gradient(135deg,rgba(0,196,232,0.2),rgba(0,180,220,0.1));border-color:rgba(0,196,232,0.3)}
    .cool-cell .sector-perf{color:#00c4e8}
    .cold-cell{background:linear-gradient(135deg,rgba(99,102,241,0.25),rgba(79,70,229,0.15));border-color:rgba(99,102,241,0.35)}
    .cold-cell .sector-perf{color:#818cf8}
    
    /* SECTORS */
    .sectors-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px}
    .sector-card{background:var(--bg-card);border-radius:10px;padding:14px;border:1px solid var(--border-subtle);transition:all 0.2s;position:relative;overflow:hidden}
    .sector-card::before{content:'';position:absolute;top:0;right:0;width:60px;height:60px;background:url('https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=100') center/cover;opacity:0.05;border-radius:0 10px 0 60px}
    .sector-card:hover{border-color:var(--accent-mint);transform:translateY(-2px)}
    .sector-card.bullish{border-top:4px solid var(--accent-green)}
    .sector-card.neutral{border-top:4px solid var(--accent-gold)}
    .sector-card.bearish{border-top:4px solid var(--accent-red)}
    .sector-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
    .sector-name{font-size:11px;font-weight:700;display:flex;align-items:center;gap:6px}
    .sector-trend{padding:3px 8px;border-radius:4px;font-size:9px;font-weight:700}
    .trend-bullish{background:rgba(16,185,129,0.15);color:var(--accent-green)}
    .trend-neutral{background:rgba(245,158,11,0.15);color:var(--accent-gold)}
    .trend-bearish{background:rgba(239,68,68,0.15);color:var(--accent-red)}
    .sector-reason{font-size:9px;color:var(--text-secondary);margin-bottom:8px;line-height:1.5;padding:8px;background:var(--bg-elevated);border-radius:6px;border-left:3px solid var(--accent-gold)}
    .sector-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:8px}
    .sector-stat{text-align:center}
    .sector-stat-value{font-size:12px;font-weight:700;font-family:var(--font-mono)}
    .sector-stat-label{font-size:8px;color:var(--text-muted)}
    .sector-stocks span{display:inline-block;background:var(--bg-elevated);padding:3px 6px;border-radius:4px;margin:2px;font-size:9px;cursor:pointer;transition:all 0.2s;font-family:var(--font-mono)}
    .sector-stocks span:hover{background:rgba(0,229,176,0.15);color:var(--accent-mint)}
    .sector-stocks span.mine{background:rgba(0,229,176,0.15);color:var(--accent-mint);font-weight:600}
    
    /* RAW DATA */
    .classify-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px}
    .classify-card{background:var(--bg-card);border-radius:10px;padding:14px;border:1px solid var(--border-subtle)}
    .classify-card h3{font-size:12px;font-weight:700;margin-bottom:10px;color:var(--accent-gold);border-bottom:1px solid var(--border-subtle);padding-bottom:8px;display:flex;align-items:center;gap:6px}
    .classify-card h3 i{width:16px;height:16px}
    .my-stocks-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:8px;margin-bottom:10px;max-height:220px;overflow-y:auto}
    .stock-card-prominent{background:linear-gradient(135deg,rgba(0,229,176,0.1),rgba(0,196,232,0.05));border:1px solid rgba(0,229,176,0.2);border-radius:8px;padding:10px;text-align:center;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden}
    .stock-card-prominent::before{content:'';position:absolute;top:-20px;right:-20px;width:50px;height:50px;background:url('https://images.unsplash.com/photo-1478436127897-769e1b3f0f36?w=100') center/cover;opacity:0.08;border-radius:50%}
    .stock-card-prominent:hover{transform:scale(1.03);border-color:var(--accent-mint);box-shadow:var(--glow-mint)}
    .stock-card-prominent .tk{font-size:12px;font-weight:700;color:var(--accent-mint);font-family:var(--font-mono)}
    .stock-card-prominent .nm{font-size:8px;color:var(--text-muted);margin:3px 0}
    .stock-card-prominent .pr{font-size:11px;font-weight:600;font-family:var(--font-mono)}
    .stock-card-prominent .chg{font-size:9px;padding:2px 8px;border-radius:4px;margin-top:4px;display:inline-block;font-weight:600}
    .chg-pos{background:rgba(16,185,129,0.15);color:var(--accent-green)}
    .chg-neg{background:rgba(239,68,68,0.15);color:var(--accent-red)}
    
    /* METHODOLOGY */
    .methodology-content{padding:10px;max-width:1100px;margin:0 auto}
    .method-section{background:var(--bg-card);border-radius:10px;padding:20px;margin-bottom:14px;border:1px solid var(--border-subtle)}
    .method-section h2{font-size:16px;color:var(--accent-gold);margin-bottom:12px;border-bottom:2px solid var(--accent-gold);padding-bottom:10px;font-weight:700;display:flex;align-items:center;gap:10px}
    .method-section h2 i{width:20px;height:20px}
    .method-section h3{font-size:12px;color:var(--accent-mint);margin:12px 0 8px 0;font-weight:600;display:flex;align-items:center;gap:6px}
    .method-section h3 i{width:14px;height:14px}
    .method-section p{font-size:11px;color:var(--text-secondary);line-height:1.7;margin-bottom:10px}
    .method-section ul{list-style:none;margin:10px 0}
    .method-section li{padding:6px 0 6px 20px;position:relative;color:var(--text-secondary);font-size:11px;line-height:1.6}
    .method-section li::before{content:'';position:absolute;left:4px;top:12px;width:6px;height:6px;background:var(--accent-mint);border-radius:50%}
    .formula-box{background:linear-gradient(135deg,rgba(0,229,176,0.1),rgba(0,196,232,0.05));border:1px solid rgba(0,229,176,0.2);border-radius:10px;padding:16px;margin:12px 0}
    .formula-box code{color:var(--accent-mint);font-size:13px;display:block;margin:8px 0;font-family:var(--font-mono);font-weight:600}
    .formula-title{font-size:12px;font-weight:700;color:var(--accent-gold);margin-bottom:8px}
    .formula-example{background:var(--bg-deep);padding:12px;border-radius:8px;margin-top:12px;font-size:11px;line-height:1.7;font-family:var(--font-mono)}
    .category-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin:14px 0}
    .category-card{background:var(--bg-elevated);border-radius:10px;padding:12px;border-top:4px solid var(--accent-mint)}
    .category-card h4{font-size:11px;font-weight:700;margin-bottom:8px}
    .category-card li{font-size:10px;padding:3px 0 3px 12px}
    
    /* FOOTER */
    .footer{background:var(--bg-panel);border-top:1px solid var(--accent-gold);padding:10px;text-align:center;position:relative;overflow:hidden}
    .footer::before{content:'';position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1490806843957-31f4c9a91c65?w=1920') center/cover;opacity:0.03}
    .footer-jp{font-family:var(--font-jp);font-size:12px;color:var(--sakura);letter-spacing:4px;margin-bottom:4px;position:relative}
