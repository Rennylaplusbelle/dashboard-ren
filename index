    .logo-text{display:flex;flex-direction:column}
    .logo-title{font-family:var(--font-jp);font-size:16px;font-weight:700;background:var(--gradient-premium);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:1px}
    .logo-sub{font-size:10px;color:var(--accent-mint);letter-spacing:3px;font-weight:500;text-transform:uppercase}
    
    .header-metrics{display:flex;gap:20px}
    .hm{display:flex;align-items:center;gap:8px;padding:6px 14px;background:var(--bg-card);border-radius:8px;border:1px solid var(--border-subtle)}
