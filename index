    }else if(selected.c==='E'||selected.c==='B'){
        ind.className='invest-indicator sell';
        ind.innerHTML='<i data-lucide="alert-triangle" class="invest-icon red"></i><div><div class="invest-text red">AVOID</div><div class="invest-sub">'+selected.type+' Signal</div></div>';
    }else{
        ind.className='invest-indicator hold';
        ind.innerHTML='<i data-lucide="pause" class="invest-icon gold"></i><div><div class="invest-text gold">WAIT</div><div class="invest-sub">No Clear Signal</div></div>';
